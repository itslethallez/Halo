# ─────────────────────────────────────────────────────────────────────────
# Halo environment variables
#
# Copy this file to `.env` and fill in real values for anything you want to
# run against a live provider. Everything below has a working DEV/MOCK
# adapter that requires NO credentials, so the app runs and can be demoed/
# tested with none of this filled in — set INTEGRATION_MODE=dev (default).
# ─────────────────────────────────────────────────────────────────────────

# --- Core -------------------------------------------------------------
NODE_ENV="development"
# Master switch: "dev" uses in-memory/console/mock adapters for every
# integration below. "live" requires the matching provider credentials.
INTEGRATION_MODE="dev"

# --- Database -----------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/halo?schema=public"

# --- Auth / sessions ------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-value"
# Field-level encryption key for sensitive columns (home address, distress
# phrase, calendar tokens, private survey notes). Generate with:
# openssl rand -hex 32
FIELD_ENCRYPTION_KEY="replace-with-a-64-char-hex-string"

# --- Google Calendar (integrations/calendar/google) ------------------------
GOOGLE_CALENDAR_CLIENT_ID=""
GOOGLE_CALENDAR_CLIENT_SECRET=""
GOOGLE_CALENDAR_REDIRECT_URI="http://localhost:3000/api/integrations/calendar/google/callback"

# --- SMS provider (integrations/sms) — e.g. Twilio -------------------------
SMS_PROVIDER="twilio"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# --- Email provider (integrations/email) — e.g. Resend/Postmark ------------
EMAIL_PROVIDER="resend"
EMAIL_API_KEY=""
EMAIL_FROM_ADDRESS="bookings@example.com"

# --- WhatsApp Business (integrations/whatsapp) -----------------------------
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""

# --- Payments (integrations/payments) — e.g. Stripe ------------------------
PAYMENTS_PROVIDER="stripe"
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PUBLISHABLE_KEY=""

# --- Maps / travel-time (integrations/maps) — e.g. Google Maps -------------
MAPS_PROVIDER="google"
MAPS_API_KEY=""

# --- Push notifications (integrations/push) — e.g. Web Push / FCM ---------
PUSH_PROVIDER="webpush"
WEB_PUSH_PUBLIC_KEY=""
WEB_PUSH_PRIVATE_KEY=""

# --- AI language model provider (integrations/ai) --------------------------
AI_PROVIDER="dev"
AI_API_KEY=""
AI_MODEL="claude-sonnet-5"
