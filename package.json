    "db:push": "prisma db push"
  },
  "dependencies": {
    "next": "15.5.20",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "@prisma/client": "6.19.3",
    "zod": "3.25.76",
    "jose": "6.2.3",
    "otplib": "12.0.1",
    "date-fns": "4.4.0",
    "clsx": "2.1.1",
    "lucide-react": "0.469.0",
    "web-push": "3.6.7"
  },
  "devDependencies": {
    "typescript": "5.9.3",
    "prisma": "6.19.3",
    "tsx": "4.23.1",
    "vitest": "3.2.7",
    "tailwindcss": "3.4.9",
    "postcss": "8.5.21",
    "autoprefixer": "10.5.4",
    "@types/node": "22.10.7",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/web-push": "3.6.4",
    "eslint": "8.57.1",
